# Public URLs and analytics
NEXT_PUBLIC_SITE_URL=https://mckot.com

# WhatsApp Business deep link (country code + number, no plus in path)
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/233XXXXXXXXX

# Optional socials used in footer + schema sameAs
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/mckot
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@mckot

# Google Analytics 4 (omit to disable gtag snippet)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend API for the /ride booking app (login + booking). Defaults to production.
API_PROXY_TARGET=https://api.mckot.com

# Booking map (Phase 2) — Google Maps JavaScript API key, browser-restricted, Places + Directions enabled.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Web OAuth for /ride social sign-in. Distinct from the mobile SDK client IDs.
# Each button only renders when its client ID is set. Google: OAuth 2.0 Web
# client ID with this origin in "Authorized JavaScript origins". Apple: the
# Services ID (not the app bundle ID), with the redirect URI below registered
# in the Apple Developer console under that Services ID.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_APPLE_OAUTH_CLIENT_ID=
# Defaults to <origin>/ride; must exactly match a Return URL on the Apple Services ID.
NEXT_PUBLIC_APPLE_OAUTH_REDIRECT_URI=

# Centrifugo websocket for live trip tracking (Phase 3). Defaults to production.
NEXT_PUBLIC_CENTRIFUGO_WS_URL=wss://ws.mckot.com/connection/websocket

# Forward vendor signups to your API (optional). If unset, submissions log server-side only.
VENDOR_SIGNUP_API_URL=
VENDOR_SIGNUP_API_KEY=

# Resend transactional email (server-only — never expose to client).
# All four required in production; missing values throw at boot.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@noreply.mckot.com
RESEND_FROM_NAME=Mckot
RESEND_REPLY_TO=contact@mckot.com

# Where internal signup/contact notifications are sent. Defaults to hello@mckot.com.
INTERNAL_NOTIFICATION_EMAIL=hello@mckot.com
