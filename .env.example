# Public URLs and analytics
NEXT_PUBLIC_SITE_URL=https://mckot.com

# WhatsApp Business deep link (country code + number, no plus in path)
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/233XXXXXXXXX

# Optional socials used in footer + schema sameAs
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/mckot
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@mckot

# Google Analytics 4 (omit to disable gtag snippet)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Forward vendor signups to your API (optional). If unset, submissions log server-side only.
VENDOR_SIGNUP_API_URL=
VENDOR_SIGNUP_API_KEY=

# Resend transactional email (server-only — never expose to client).
# All four required in production; missing values throw at boot.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@noreply.mckot.com
RESEND_FROM_NAME=Mckot
RESEND_REPLY_TO=contact@mckot.com

# Where internal signup/contact notifications are sent. Defaults to hello@mckot.com.
INTERNAL_NOTIFICATION_EMAIL=hello@mckot.com
